# Copy to secrets.env (gitignored). Values can be pass:// URIs resolved by pass-cli run.
# Example wrapper: pass-cli run --env-file secrets.env -- bash scripts/renovate-review-agent.sh
#
# Homelab vault items (each is a Login item; field is "password"):
#   CURSOR_API_KEY, GITHUB_TOKEN, KEYCHAIN_PASSWORD

CURSOR_API_KEY=pass://Homelab/CURSOR_API_KEY/password
GITHUB_TOKEN=pass://Homelab/GITHUB_TOKEN/password
KEYCHAIN_PASSWORD=pass://Homelab/KEYCHAIN_PASSWORD/password
KEYCHAIN_PATH=/Users/luissousa/Library/Keychains/login.keychain-db
